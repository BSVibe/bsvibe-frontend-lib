{
  "name": "@bsvibe/auth",
  "version": "0.0.1",
  "description": "BSVibe authentication SDK (Next.js middleware + Server Action getServerUser + Client Hook useAuth)",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BSVibe/bsvibe-frontend-lib.git",
    "directory": "packages/auth"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "echo \"(no tests yet — placeholder)\" && exit 0",
    "clean": "rm -rf dist .tsbuildinfo *.tsbuildinfo"
  },
  "dependencies": {
    "@bsvibe/types": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=15.0.0",
    "react": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "next": { "optional": true },
    "react": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
