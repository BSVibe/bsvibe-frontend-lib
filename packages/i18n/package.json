{
  "name": "@bsvibe/i18n",
  "version": "0.1.0",
  "description": "BSVibe i18n — next-intl wrapper with shared common/auth namespaces (ko/en)",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "src/messages"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js"
    },
    "./provider": {
      "types": "./dist/provider.d.ts",
      "import": "./dist/provider.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.js"
    },
    "./messages/*": "./src/messages/*",
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BSVibe/bsvibe-frontend-lib.git",
    "directory": "packages/i18n"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist .tsbuildinfo *.tsbuildinfo coverage"
  },
  "peerDependencies": {
    "next": ">=15.0.0",
    "next-intl": ">=4.0.0",
    "react": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "next": { "optional": true },
    "next-intl": { "optional": false },
    "react": { "optional": false }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^29.0.2",
    "next": "^16.0.0",
    "next-intl": "^4.9.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.6.0",
    "vitest": "^4.1.3"
  }
}
