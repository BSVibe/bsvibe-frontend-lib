{
  "name": "@bsvibe/i18n",
  "version": "0.0.1",
  "description": "BSVibe i18n — next-intl wrapper with shared common/auth namespaces (ko/en)",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "messages"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./messages/*": "./messages/*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BSVibe/bsvibe-frontend-lib.git",
    "directory": "packages/i18n"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "echo \"(no tests yet — placeholder)\" && exit 0",
    "clean": "rm -rf dist .tsbuildinfo *.tsbuildinfo"
  },
  "peerDependencies": {
    "next": ">=15.0.0",
    "next-intl": ">=3.0.0",
    "react": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "next": { "optional": true },
    "next-intl": { "optional": true },
    "react": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
