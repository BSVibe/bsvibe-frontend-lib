{
  "name": "@bsvibe/ui",
  "version": "0.0.1",
  "description": "BSVibe UI primitives — Button/Modal/Badge/Input/Card + Storybook (GitHub Pages)",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BSVibe/bsvibe-frontend-lib.git",
    "directory": "packages/ui"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "echo \"(no tests yet — placeholder)\" && exit 0",
    "storybook": "echo \"(storybook config lands in Phase A subsequent PR)\" && exit 0",
    "build-storybook": "echo \"(storybook config lands in Phase A subsequent PR)\" && exit 0",
    "clean": "rm -rf dist .tsbuildinfo *.tsbuildinfo storybook-static"
  },
  "dependencies": {
    "@bsvibe/design-tokens": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
