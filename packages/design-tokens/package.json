{
  "name": "@bsvibe/design-tokens",
  "version": "0.0.1",
  "description": "BSVibe design tokens — Tailwind 4 preset + CSS variables (stitch-* palette)",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "css"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css": "./css/tokens.css"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BSVibe/bsvibe-frontend-lib.git",
    "directory": "packages/design-tokens"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "echo \"(no tests yet — placeholder)\" && exit 0",
    "clean": "rm -rf dist .tsbuildinfo *.tsbuildinfo"
  },
  "peerDependencies": {
    "tailwindcss": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
