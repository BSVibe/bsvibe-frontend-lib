{
  "name": "@bsvibe/design-tokens",
  "version": "0.1.0",
  "description": "BSVibe design tokens — TypeScript source of truth + Tailwind 4 @theme CSS variables (gray/brand/alias/Material 3)",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "styles",
    "tools",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tailwind": {
      "types": "./dist/tailwind.d.ts",
      "import": "./dist/tailwind.js"
    },
    "./css": "./styles/globals.css",
    "./styles/globals.css": "./styles/globals.css",
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BSVibe/bsvibe-frontend-lib.git",
    "directory": "packages/design-tokens"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "node tools/verify-tokens.mjs",
    "clean": "rm -rf dist .tsbuildinfo *.tsbuildinfo"
  },
  "peerDependencies": {
    "tailwindcss": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^4.1.3"
  }
}
