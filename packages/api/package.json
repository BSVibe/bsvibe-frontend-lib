{
  "name": "@bsvibe/api",
  "version": "0.1.0",
  "description": "BSVibe API client — Server fetch + Server Action wrapper + Vercel→Route Handler adapter + 401 cascade guard + dual-env reader",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BSVibe/bsvibe-frontend-lib.git",
    "directory": "packages/api"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run && vitest run --typecheck.enabled --typecheck.only --typecheck.include 'src/**/*.test-d.ts'",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist .tsbuildinfo *.tsbuildinfo"
  },
  "dependencies": {
    "@bsvibe/auth": "workspace:*",
    "@bsvibe/types": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=15.0.0",
    "react": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "next": { "optional": true },
    "react": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.3",
    "typescript": "^5.6.0",
    "vitest": "^4.1.3"
  }
}
