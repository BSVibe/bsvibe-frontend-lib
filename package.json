{
  "name": "@bsvibe/workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "BSVibe shared frontend libraries (pnpm workspace, npm packages)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BSVibe/bsvibe-frontend-lib.git"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "build": "pnpm -r --parallel run build",
    "lint": "pnpm -r --parallel run lint",
    "test": "pnpm -r --parallel run test",
    "typecheck": "pnpm -r --parallel run typecheck",
    "clean": "pnpm -r --parallel run clean"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.10.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  }
}
